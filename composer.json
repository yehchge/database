{
    "name": "yehchge/database",
    "description": "MySQL Database C.R.U.D",
    "type": "library",
    "license":"MIT",
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^4.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2"
    },
    "require": {
        "php":">=5.3.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf"
    },
    "archive": {
        "exclude": ["*.sh", "tests/", "README.md", ".gitignore", "*.zip", "*.xml"]
    },
    "autoload": {
        "psr-4": {
           "yehchge\\database\\": "src/"
       }
    },
    "autoload-dev": {
        "psr-4": {
           "yehchge\\database\\": ["src/", "tests/"]
        },
        "classmap": ["tests/"]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
